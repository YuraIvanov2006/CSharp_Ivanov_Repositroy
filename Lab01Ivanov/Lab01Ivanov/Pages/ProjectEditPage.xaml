<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab01Ivanov.Pages.ProjectEditPage"
             Title="{Binding PageTitle}"
             BackgroundColor="#1A1A2E">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Name" TextColor="#8080A0" FontSize="13" />
            <Entry Text="{Binding Name}" Placeholder="Project name"
                   BackgroundColor="#16213E" TextColor="#E0E0F0"
                   PlaceholderColor="#505070" />

            <Label Text="Description" TextColor="#8080A0" FontSize="13" />
            <Editor Text="{Binding Description}" Placeholder="Short description"
                    BackgroundColor="#16213E" TextColor="#E0E0F0"
                    PlaceholderColor="#505070" HeightRequest="100" />

            <Label Text="Type" TextColor="#8080A0" FontSize="13" />
            <Picker ItemsSource="{Binding TypeOptions}"
                    SelectedItem="{Binding Type}"
                    BackgroundColor="#16213E" TextColor="#E0E0F0" />

            <Button Text="💾  Save"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#E94560" TextColor="White"
                    CornerRadius="10" HeightRequest="50" Margin="0,10,0,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

            <Button Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="#16213E" TextColor="#8080A0"
                    CornerRadius="10" HeightRequest="44" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#E94560" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
