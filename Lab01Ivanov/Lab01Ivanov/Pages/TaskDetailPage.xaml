<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab01Ivanov.Pages.TaskDetailPage"
             Title="{Binding Task.Name}"
             BackgroundColor="#1A1A2E">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="✏️ Edit" Command="{Binding EditCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Frame CornerRadius="12" Padding="16,12" BackgroundColor="#16213E">
                <Label Text="{Binding Task.StatusText}"
                       FontSize="15" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="#4FC3F7" />
            </Frame>
            <Frame BackgroundColor="#16213E" CornerRadius="14" Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding Task.Name}"
                           FontSize="19" FontAttributes="Bold" TextColor="#E0E0F0" />
                    <Label Text="{Binding Task.Description}"
                           FontSize="13" TextColor="#A0A0B0" />
                    <BoxView HeightRequest="1" Color="#2A2A4A" />
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnDefinitions="Auto,*" RowSpacing="10" ColumnSpacing="16">
                        <Label Grid.Row="0" Grid.Column="0" Text="Priority" TextColor="#8080A0" FontSize="13" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Task.PriorityDisplay}"
                               FontSize="13" FontAttributes="Bold" TextColor="#4FC3F7" />
                        <Label Grid.Row="1" Grid.Column="0" Text="Due Date" TextColor="#8080A0" FontSize="13" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Task.DueDateDisplay}"
                               FontSize="13" TextColor="#E0E0F0" />
                        <Label Grid.Row="2" Grid.Column="0" Text="Completed" TextColor="#8080A0" FontSize="13" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding Task.IsCompleted, Converter={StaticResource BoolToYesNoConverter}}"
                               FontSize="13" TextColor="#66BB6A" />
                        <Label Grid.Row="3" Grid.Column="0" Text="Overdue" TextColor="#8080A0" FontSize="13" />
                        <Label Grid.Row="3" Grid.Column="1"
                               Text="{Binding Task.IsOverdue, Converter={StaticResource BoolToYesNoConverter}}"
                               FontSize="13" TextColor="#EF5350" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#E94560" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
