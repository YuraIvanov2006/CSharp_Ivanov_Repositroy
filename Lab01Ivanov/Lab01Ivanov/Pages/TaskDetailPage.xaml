<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab01Ivanov.Pages.TaskDetailPage"
             Title="Task Details"
             BackgroundColor="#1A1A2E">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Status banner -->
            <Frame x:Name="StatusBanner" CornerRadius="12" Padding="16,12">
                <Label x:Name="StatusLabel" FontSize="16" FontAttributes="Bold"
                       HorizontalOptions="Center" />
            </Frame>

            <!-- Main info card -->
            <Frame BackgroundColor="#16213E" CornerRadius="14" Padding="20">
                <VerticalStackLayout Spacing="14">

                    <Label x:Name="TaskNameLabel"
                           FontSize="20" FontAttributes="Bold" TextColor="#E0E0F0" />

                    <Label x:Name="TaskDescLabel"
                           FontSize="14" TextColor="#A0A0B0" />

                    <BoxView HeightRequest="1" Color="#2A2A4A" />

                    <!-- Field grid -->
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnDefinitions="Auto,*"
                          RowSpacing="10" ColumnSpacing="16">

                        <Label Grid.Row="0" Grid.Column="0" Text="Priority"
                               TextColor="#8080A0" FontSize="13" />
                        <Label x:Name="PriorityLabel" Grid.Row="0" Grid.Column="1"
                               FontSize="13" FontAttributes="Bold" TextColor="#4FC3F7" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Due Date"
                               TextColor="#8080A0" FontSize="13" />
                        <Label x:Name="DueDateLabel" Grid.Row="1" Grid.Column="1"
                               FontSize="13" TextColor="#E0E0F0" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Completed"
                               TextColor="#8080A0" FontSize="13" />
                        <Label x:Name="CompletedLabel" Grid.Row="2" Grid.Column="1"
                               FontSize="13" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Overdue"
                               TextColor="#8080A0" FontSize="13" />
                        <Label x:Name="OverdueLabel" Grid.Row="3" Grid.Column="1"
                               FontSize="13" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
