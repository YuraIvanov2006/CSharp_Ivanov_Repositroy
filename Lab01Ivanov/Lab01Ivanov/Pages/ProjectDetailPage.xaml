<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lab01Ivanov.Pages.ProjectDetailPage"
             Title="{Binding Project.Name}"
             BackgroundColor="#1A1A2E">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="✏️ Edit" Command="{Binding EditProjectCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Project info card -->
                <Frame Margin="12,12,12,6" BackgroundColor="#16213E" CornerRadius="14" Padding="18">
                    <VerticalStackLayout Spacing="7">
                        <Label Text="{Binding Project.Name}"
                               FontSize="20" FontAttributes="Bold" TextColor="#E94560" />
                        <Border BackgroundColor="#0F3460" StrokeShape="RoundRectangle 8"
                                Padding="10,3" HorizontalOptions="Start">
                            <Label Text="{Binding Project.TypeDisplay}" FontSize="11" TextColor="#4FC3F7" />
                        </Border>
                        <Label Text="{Binding Project.Description}" FontSize="13" TextColor="#A0A0B0" />
                        <Label FontSize="12" TextColor="#4FC3F7">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Progress: " TextColor="#8080A0" />
                                    <Span Text="{Binding Project.Progress, StringFormat='{0:F1}%'}" FontAttributes="Bold" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <ProgressBar Progress="{Binding Project.ProgressFraction}" ProgressColor="#4FC3F7" />
                        <Label FontSize="11" TextColor="#8080A0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Project.TotalTasks}" />
                                    <Span Text=" tasks  •  " />
                                    <Span Text="{Binding Project.CompletedTasks}" />
                                    <Span Text=" done  •  " />
                                    <Span Text="{Binding Project.OverdueTasks}" />
                                    <Span Text=" overdue" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Frame>

                <!-- Task search + sort + add -->
                <Grid Padding="12,4" ColumnDefinitions="*,140,50" ColumnSpacing="6">
                    <SearchBar Grid.Column="0" Text="{Binding TaskSearch}"
                               Placeholder="Search tasks..." PlaceholderColor="#505070"
                               BackgroundColor="#16213E" TextColor="#E0E0F0" />
                    <Picker Grid.Column="1" ItemsSource="{Binding TaskSortOptions}"
                            SelectedItem="{Binding TaskSort}"
                            BackgroundColor="#16213E" TextColor="#4FC3F7" />
                    <Button Grid.Column="2" Text="＋" Command="{Binding AddTaskCommand}"
                            BackgroundColor="#E94560" TextColor="White" CornerRadius="8" FontSize="20" />
                </Grid>

                <Label Text="Tasks" Margin="16,4,16,2"
                       FontSize="16" FontAttributes="Bold" TextColor="#E0E0F0" />

                <!-- Task list -->
                <CollectionView ItemsSource="{Binding Project.Tasks}"
                                SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                                SelectionMode="Single" HeightRequest="500">
                    <CollectionView.EmptyView>
                        <Label Text="No tasks yet." HorizontalOptions="Center"
                               TextColor="#8080A0" Margin="0,20" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,3">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Delete" BackgroundColor="#E94560"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTaskCommand}"
                                                       CommandParameter="{Binding .}" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Frame CornerRadius="10" Padding="12,8" HasShadow="False"
                                           BackgroundColor="#16213E">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Label Grid.Column="0" Text="{Binding StatusIcon}"
                                                   FontSize="16" VerticalOptions="Center" />
                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Label Text="{Binding Name}"
                                                       FontSize="13" FontAttributes="Bold" TextColor="#E0E0F0" />
                                                <Label FontSize="10" TextColor="#8080A0">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="Due: " />
                                                            <Span Text="{Binding DueDate, StringFormat='{0:yyyy-MM-dd}'}" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </VerticalStackLayout>
                                            <Border Grid.Column="2" BackgroundColor="#1A1A2E"
                                                    StrokeShape="RoundRectangle 6" Padding="6,2" VerticalOptions="Center">
                                                <Label Text="{Binding PriorityDisplay}"
                                                       FontSize="9" TextColor="#4FC3F7" />
                                            </Border>
                                        </Grid>
                                    </Frame>
                                </SwipeView>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="#E94560" HorizontalOptions="Center" Margin="0,8" />
    </Grid>
</ContentPage>
